DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

TAIJIAN_PLOT_MODEL=deepseek/deepseek-chat
TAIJIAN_DRAFT_MODEL=deepseek/deepseek-chat
TAIJIAN_STYLE_MODEL=deepseek/deepseek-chat
TAIJIAN_QUALITY_MODEL=deepseek/deepseek-chat
TAIJIAN_LIGHTRAG_MODEL=deepseek-chat

TAIJIAN_EMBEDDING_BACKEND=local-hash
TAIJIAN_EMBEDDING_DIM=384
TAIJIAN_RAG_QUERY_MODE=mix
TAIJIAN_WEB_HOST=127.0.0.1
TAIJIAN_WEB_PORT=8000
TAIJIAN_WEB_USERNAME=admin
TAIJIAN_WEB_PASSWORD=
TAIJIAN_WEB_MODEL_OPTIONS=deepseek/deepseek-chat,deepseek/deepseek-reasoner,openai/gpt-4.1-mini
TAIJIAN_WEB_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Optional: only needed if you switch embedding backend to openai
OPENAI_API_KEY=
TAIJIAN_EMBEDDING_MODEL=text-embedding-3-small
